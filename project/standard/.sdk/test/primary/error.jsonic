
basic: set: [
  { args:[{}], err:'ProjectNameSDK: unknown operation: unknown error' }
  { args:[{},{}], err:'ProjectNameSDK: unknown operation: unknown error' }

  { args:[{opname:foo}], err:'ProjectNameSDK: foo: unknown error' }
  { args:[{opname:foo,result:{}}], err:'ProjectNameSDK: foo: unknown error' }

  { args:[{opname:foo,result:{err:{message:bar}}}], err:'ProjectNameSDK: foo: bar' }
  { args:[{opname:foo}, {message:zed}], err:'ProjectNameSDK: foo: zed' }

  { args:[{opname:o0}, {message:e0}], err:'ProjectNameSDK: o0: e0'
    match: err:message:'ProjectNameSDK: o0: e0'
  }

]
