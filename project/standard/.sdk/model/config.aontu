# SDK Configuration

main: kit: config: {

  # The Authorization credential prefix is derived from the OpenAPI
  # security scheme (see api/api-info.aontu: main.kit.info.security,
  # set by apidef) and defaults to 'Bearer' when the spec gives no
  # signal. Uncomment to override per-SDK:
  # auth: prefix: 'Bearer'


  headers: {
    'content-type': 'application/json'
  }

}
